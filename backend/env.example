# PostgreSQL Database
POSTGRES_USER=coachflo
POSTGRES_PASSWORD=coachflo
POSTGRES_DB=coachflo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (можно использовать вместо отдельных переменных)
DATABASE_URL=postgresql://coachflo:coachflo@localhost:5432/coachflo

# JWT Secret Key (ОБЯЗАТЕЛЬНО измените в продакшене!)
SECRET_KEY=your-secret-key-change-in-production-please-use-strong-random-key

# CORS Origins (для фронтенда, через запятую)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

TG_GATEWAY_TOKEN=your_tg_gateway_token
SMSC_LOGIN=your_smsc_login
